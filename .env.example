# Шаблон переменных окружения IndiaHorizone
# Скопировать в .env и заполнить. Никогда не коммитить .env.
# Источник секретов в проде: см. docs/ARCH/SECURITY/SECRETS.md (issue #69)

# === Базовое ===
NODE_ENV=development

# === API (apps/api, NestJS) ===
API_HOST=0.0.0.0
API_PORT=4000

# === Web (apps/web, Next.js) — задаётся отдельно через next dev ===
# WEB_PORT=3000
# NEXT_PUBLIC_API_URL=http://localhost:4000

# === База данных ===
# PostgreSQL — основная БД (database-per-service в фазе 4, см. issue #62)
DATABASE_URL=postgresql://user:password@localhost:5432/indiahorizone

# === Кеш и очереди ===
REDIS_URL=redis://localhost:6379

# === Авторизация ===
# Сгенерировать: openssl rand -base64 64
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# === AI (фаза 2+) ===
# OpenAI / Anthropic — для Trip Companion и Manager Assistant (issue #61, #67)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# === Уведомления ===
TELEGRAM_BOT_TOKEN=
FCM_SERVER_KEY=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_PRIVATE_KEY_PATH=

# === Файлы ===
# В РФ-облаке для соответствия 152-ФЗ (issue #49)
# Yandex Cloud Object Storage / Selectel S3 / VK Cloud
S3_ENDPOINT=
S3_REGION=ru-central1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# === Карты ===
MAPBOX_TOKEN=

# === SOS-каналы ===
# Twilio для голосового резерва (issue #28)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Резервные SMS-операторы — РФ и IN
SMS_RU_API_KEY=
SMS_IN_API_KEY=

# === Платёжный шлюз (фаза 4) ===
# YooKassa / CloudPayments / Tinkoff — issue #12
PAYMENT_PROVIDER=
PAYMENT_API_KEY=
PAYMENT_SHOP_ID=

# === Observability ===
# OpenTelemetry collector (issue #75)
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=

# === Inter-co IN ===
# Доступ к API партнёра в Индии (наше IN PVT LTD) — если применимо
IN_INTERNAL_API_URL=
IN_INTERNAL_API_KEY=
